# Required in production. Set via Cloudflare secret for deploy/runtime.
PAYLOAD_SECRET=replace-with-strong-secret

# Public URL used by Payload for links and API responses.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: trace|debug|info|warn|error|fatal
PAYLOAD_LOG_LEVEL=info

# Optional environment selector for wrangler/getPlatformProxy.
CLOUDFLARE_ENV=

# Local dev safety toggle. Keep false unless you explicitly want remote D1/R2.
CLOUDFLARE_REMOTE_BINDINGS=false
