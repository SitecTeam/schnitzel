{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "schnitzel-cms",
  "account_id": "e2b2bd369383697806442a2ce0648be0",
  "compatibility_date": "2026-01-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "D1",
      "database_name": "schnitzel-db",
      "database_id": "44ebdcda-99d1-4d46-9988-b77ca6abf5cd",
      "remote": true
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "schnitzel-media",
      "remote": true
    }
  ],
  "rules": [{ "type": "CompiledWasm", "globs": ["**/*.wasm"] }],
  "vars": {
    "NODE_ENV": "production",
    "PAYLOAD_PUBLIC_SERVER_URL": "https://schnitzelshow.com",
    "PAYLOAD_PUBLIC_MEDIA_URL": "https://media.schnitzelshow.com"
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    }
  }
}
