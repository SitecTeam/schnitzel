---
import { ArrowDown } from "lucide-react";
import Typography from "../typography";
---

<section
  class="mx-auto flex justify-center bg-secondary px-4 pb-12 lg:max-w-432.5 lg:bg-transparent lg:px-10 lg:pb-25"
>
  <div
    class="z-20 -mt-12 bg-primary px-4 py-9 text-primary-foreground sm:px-6 sm:py-10 lg:-mt-11 lg:p-10 xl:-mt-18 xl:p-16"
  >
    <div class="flex min-h-105 flex-col gap-8 lg:flex-row">
      <Typography
        variant="h1"
        tag="h1"
        className="basis-2/5 uppercase lg:-mt-2.5"
      >
        About Us
      </Typography>

      <div class="flex flex-1 flex-col gap-8 text-pretty 2xl:gap-16">
        <Typography variant="h5" tag="h5">
          A climbing-centered podcast featuring climbers and unique voices from
          across the outdoor and creative spectrum.
        </Typography>
        <Typography variant="h5" tag="h5">
          Conversations range from training methods and coaching philosophies to
          injury recovery, mindset, and pivotal life events that reshape
          identity.
        </Typography>
        <Typography variant="h5" tag="h5">
          Exploring the intersection of climbing, art, and resilience in modern
          times. By the one and only Wolf Schnitzel.
        </Typography>
      </div>
    </div>

    <div
      class="mt-18 flex flex-col justify-between gap-2 lg:mt-16 lg:flex-row lg:gap-8"
    >
      <Typography
        variant="caption"
        tag="span"
        className="hidden basis-2/5 lg:block">Since 2020</Typography
      >
      <Typography
        variant="caption"
        tag="span"
        className="flex flex-1 items-center"
      >
        Keep scrolling, the good stuff's just below the ledge.
        <ArrowDown
          aria-hidden="true"
          className="relative ml-1 inline-block size-6 shrink-0"
        />
      </Typography>
    </div>
  </div>
</section>
