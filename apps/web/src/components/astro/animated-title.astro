---
import Typography, { textVariants } from "@/components/typography";
import { cn } from "@/lib/utils";
import type { VariantProps } from "class-variance-authority";

interface Props extends VariantProps<typeof textVariants> {
  title: string;
  className?: string;
}

const {
  title,
  className,
  variant = "display-md",
  uppercase = true,
} = Astro.props;

const words = title.trim().split(/\s+/).filter(Boolean);
---

<Typography
  tag="h1"
  variant={variant}
  uppercase={uppercase}
  className={cn("animated-title", className)}
  aria-label={title}
>
  {
    words.map((word, index) => (
      <>
        <span class="animated-title__word-mask">
          <span
            class="animated-title__word"
            style={`--word-index: ${index};`}
            aria-hidden="true"
          >
            {word}
          </span>
        </span>
        {index < words.length - 1 && " "}
      </>
    ))
  }
</Typography>

<style>
  .animated-title__word-mask {
    display: inline-block;
    overflow: clip;
    vertical-align: top;
  }

  .animated-title__word {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.9em);
    animation: animated-title-enter 700ms cubic-bezier(0.22, 1, 0.36, 1)
      forwards;
    animation-delay: calc(var(--word-index) * 80ms + 80ms);
    will-change: transform, opacity;
  }

  @keyframes animated-title-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animated-title__word {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
