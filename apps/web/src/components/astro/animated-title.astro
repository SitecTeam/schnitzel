---
import Typography, { textVariants } from "@/components/typography";
import { cn } from "@/lib/utils";
import type { VariantProps } from "class-variance-authority";

interface Props extends VariantProps<typeof textVariants> {
  title: string;
  className?: string;
}

const {
  title,
  className,
  variant = "display-md",
  uppercase = true,
} = Astro.props;
---

<Typography
  tag="h1"
  variant={variant}
  uppercase={uppercase}
  className={cn("title invisible", className)}
>
  {title}
</Typography>

<noscript>
  <style>
    .title {
      visibility: visible !important;
    }
  </style>
</noscript>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  async function animateTitle() {
    const element = document.querySelector(".title");
    if (!element) return;

    document.fonts.ready.then(() => {
      const split = SplitText.create(element, {
        type: "words",
      });

      gsap.set(element, { visibility: "visible" });

      gsap.from(split.words, {
        y: 100,
        autoAlpha: 0,
        stagger: 0.08,
        ease: "power3.out",
      });
    });
  }

  document.addEventListener("astro:page-load", animateTitle);
</script>
