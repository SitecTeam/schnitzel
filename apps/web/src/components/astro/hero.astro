---
import Typography from "@/components/typography";
import PodcastButton from "@/components/astro/podcast-button.astro";
import heroImage from "@/assets/hero.png";
import heroMobileImage from "@/assets/hero-mobile.png";

interface Props {
  title?: string;
  heroImageAlt?: string;
}

const {
  title = "The world of climbing, served Schnitzel-style.",
  heroImageAlt = "Schnitzel podcast hero collage",
} = Astro.props;
---

<section
  class="flex min-h-[calc(100dvh-64px)] items-center overflow-x-clip overflow-y-visible bg-secondary lg:min-h-[calc(100dvh-114px)]"
>
  <div
    class="mx-auto grid w-full max-w-432.5 grid-cols-1 items-center gap-0 px-4 py-8 lg:grid-cols-2 lg:gap-8 lg:px-8 lg:py-12 xl:grid-cols-[52%_48%] xl:gap-0 xl:py-0 xl:pr-14.75 xl:pl-24"
  >
    <!-- Left: copy -->
    <div class="flex flex-col gap-5 md:gap-6 xl:gap-8">
      <!-- Heading: scales across all breakpoints -->
      <Typography
        tag="h1"
        variant="display-md"
        uppercase={true}
        className="text-balance text-primary-foreground 3xl:text-[112px] 3xl:leading-31 sm:text-pretty md:text-[64px] md:leading-19.25 lg:text-[64px] lg:leading-19.25 xl:text-[72px] xl:leading-21 2xl:text-[96px] 2xl:leading-27.5"
      >
        {title}
      </Typography>

      <!-- Description: scales across all breakpoints, line-breaks at 3xl -->
      <Typography
        tag="p"
        variant="body-lg"
        className="text-pretty text-primary-foreground lg:text-[24px] lg:leading-9.5"
      >
        <span class="desc-piece"
          >Talks with the world's most inspiring climbers, adventurers,</span
        ><span class="desc-piece">
          and thinkers — exploring the human side of climbing,</span
        ><span class="desc-piece"> training, and living boldly.</span>
      </Typography>

      <div class="flex flex-wrap gap-3 xl:gap-4">
        <PodcastButton variant="primary" class="h-12.5" />
        <PodcastButton
          variant="secondary"
          class="hidden rounded-xs border-2 border-primary-foreground text-primary-foreground sm:flex"
        />
      </div>
    </div>

    <!-- Right: hero collage image (lg+) -->
    <div
      class="relative z-10 -mb-24 flex items-end justify-center md:mt-0 lg:z-auto lg:mt-0 lg:mb-0 lg:items-center"
    >
      <img
        src={heroMobileImage.src}
        alt={heroImageAlt}
        width={756}
        height={756}
        class="w-[116vw] max-w-none origin-bottom translate-x-2 scale-110 object-contain drop-shadow-xl sm:mt-20 sm:w-[80vw] sm:scale-120 md:mt-0 md:scale-105 lg:hidden"
        loading="eager"
      />
      <img
        src={heroImage.src}
        alt={heroImageAlt}
        width={756}
        height={756}
        class="hidden w-full max-w-189 object-contain drop-shadow-xl lg:block"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .desc-piece {
    display: inline;
  }
  @media (min-width: 1606px) {
    .desc-piece {
      display: block;
    }
  }
</style>
