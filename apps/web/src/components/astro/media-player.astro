---
import mediaPlayer from "@/assets/media-player.png";
import Typography from "@/components/typography";
---

<section class="order-2 bg-primary-foreground lg:order-4 lg:mt-16 lg:pb-35.75">
  <div class="mx-auto w-full max-w-7xl px-4 md:px-8">
    <div class="relative mx-auto w-full max-w-216">
      <img
        src={mediaPlayer.src}
        alt="Schnitzel media player"
        class="mx-auto block h-auto max-h-[calc(100dvh-64px)] w-full max-w-150 lg:max-w-190"
      />
      <!-- Desktop overlays (hidden on mobile) -->
      <div class="pointer-events-none absolute inset-0 z-10 hidden lg:block">
        {/* Left callout: No scripts */}
        <div
          class="absolute top-[30%] left-2 rounded-xl bg-[#16D8D3] p-3 text-center text-primary-foreground shadow-lg lg:-left-28 lg:w-fit xl:-left-48 xl:w-64 xl:px-4 xl:py-3 2xl:px-5 2xl:py-4"
        >
          <Typography
            tag="p"
            variant="h6"
            className="text-center text-primary-foreground lg:text-[20px] lg:leading-[27px] 2xl:text-[24px] 2xl:leading-[31px]"
          >
            <span class="block">No scripts. No filters.</span>
            <span class="block">Just Schnitzel.</span>
          </Typography>
        </div>

        {/* Top-right callout: New Episode */}
        <div
          class="absolute top-[13%] right-2 w-40 rounded-xl bg-[#16D8D3] p-3 text-center text-primary-foreground shadow-lg lg:-right-28 xl:-right-40 xl:w-48 xl:px-4 xl:py-3 2xl:px-5 2xl:py-4"
        >
          <Typography
            tag="p"
            variant="h6"
            className="text-primary- text-center lg:text-[20px] lg:leading-[27px] 2xl:text-[24px] 2xl:leading-[31px]"
          >
            <span class="block">New Episode</span>
            <span class="block">every week</span>
          </Typography>
        </div>

        {/* Right callout: Conversations */}
        <div
          class="absolute top-[64%] right-2 w-60 rounded-xl bg-[#FFC567] p-3 text-center text-primary-foreground shadow-lg lg:-right-30 xl:-right-48 xl:w-80 xl:px-4 xl:py-3 2xl:px-5 2xl:py-4"
        >
          <Typography
            tag="p"
            variant="h6"
            className="text-center text-primary-foreground lg:text-[20px] lg:leading-[27px] 2xl:text-[24px] 2xl:leading-[31px]"
          >
            <span class="block">Conversations with Guests</span>
            <span class="block">from around the world</span>
          </Typography>
        </div>

        {/* Bottom-left callout: Listen on Podbean & YouTube */}
        <div
          class="absolute bottom-6 left-2 w-52 rounded-xl bg-primary p-3 text-center text-primary-foreground shadow-lg lg:-left-20 xl:-left-30 xl:w-64 xl:px-4 xl:py-3 2xl:px-5 2xl:py-4"
        >
          <Typography
            tag="p"
            variant="h6"
            className="text-center text-primary-foreground lg:text-[20px] lg:leading-[27px] 2xl:text-[24px] 2xl:leading-[31px]"
          >
            <span class="block">Listen on Podbean</span>
            <span class="block">& YouTube</span>
          </Typography>
        </div>
      </div>
    </div>
  </div>
</section>
