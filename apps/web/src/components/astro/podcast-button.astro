---
import { cn } from "@/lib/utils";
import { Button, buttonVariants } from "@/components/ui/button";
import { Play } from "lucide-react";
import Typography from "@/components/typography";

interface Props {
  variant?: "primary" | "secondary";
  href?: string;
  class?: string;
}

const { class: className, variant = "primary", href } = Astro.props;
---

<Button asChild>
  <a
    target="_blank"
    rel="noopener noreferrer"
    href={href
      ? href
      : variant === "primary"
        ? "https://schnitzelshow.podbean.com/"
        : "https://www.youtube.com/@schnitzelsnow"}
    class={cn(
      buttonVariants({ variant }),
      variant === "secondary" && "xl:pr-6",
      className
    )}
  >
    <Typography tag="span" variant="button-regular">
      {variant === "primary" ? "Listen Now" : "Watch On Youtube"}
    </Typography>
    <Play className="size-4 xl:size-5" />
  </a>
</Button>
