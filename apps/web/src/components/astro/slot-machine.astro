---
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
  disabled?: boolean;
}

const { class: className, disabled = false } = Astro.props;
const content = await Astro.slots.render("default");
---

<span
  class={cn(
    "relative inline-flex shrink-0 items-center overflow-hidden",
    className
  )}
>
  <span
    class={cn(
      "inline-flex items-center transition-transform duration-200 ease-in-out",
      !disabled && "group-hover:-translate-y-[140%]"
    )}
    set:html={content}
  />
  <span
    class={cn(
      "absolute inset-0 inline-flex translate-y-[140%] items-center transition-transform duration-200 ease-in-out",
      !disabled && "group-hover:translate-y-0"
    )}
    aria-hidden="true"
    set:html={content}
  />
</span>
