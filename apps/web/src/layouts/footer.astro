---
import Typography, { textVariants } from "@/components/typography";
import FooterLogo from "@/assets/svgs/footer-logo.svg?url";
import { cn } from "@/lib/utils";

const navigation = [
  { name: "home", href: "/" },
  { name: "episodes", href: "/episodes" },
  { name: "contact", href: "/contact" },
];

const socials = [
  { name: "podbean", href: "https://schnitzelshow.podbean.com/" },
  { name: "youtube", href: "https://www.youtube.com/@schnitzelsnow" },
  {
    name: "instagram",
    href: "https://www.instagram.com/schnitzelsnow/profilecard/",
  },
];
---

<footer
  aria-label="footer"
  class="relative flex w-full items-center overflow-y-clip bg-secondary text-white lg:min-h-130 2xl:min-h-156"
>
  {/* Grid Background Desktop*/}
  <div
    class="pointer-events-none absolute inset-0 -mt-4 hidden opacity-70 lg:block"
    style={{
      backgroundImage: `
        linear-gradient(to right, rgba(255, 255, 255, 0.3) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255, 255, 255, 0.3) 1px, transparent 1px)
      `,
      backgroundSize: "46px 46px",
    }}
    aria-hidden="true"
  >
  </div>

  {/* Grid Background Mobile */}
  <div
    class="pointer-events-none absolute inset-0 -mt-4 -ml-3 opacity-70 lg:hidden"
    style={{
      backgroundImage: `
        linear-gradient(to right, rgba(255, 255, 255, 0.3) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255, 255, 255, 0.3) 1px, transparent 1px)
      `,
      backgroundSize: "34.5px 34.5px",
    }}
    aria-hidden="true"
  >
  </div>

  <div
    class="mx-auto flex h-full max-w-432.5 flex-1 flex-col justify-between gap-18 px-4 pt-54 pb-25.5 lg:-mt-2 lg:flex-row lg:items-center lg:gap-6 lg:pt-8 lg:pb-8"
  >
    {/* Left Column: Logo & Button */}
    <div class="flex flex-1 flex-col items-center gap-8">
      <div class="relative flex flex-col items-center gap-10 lg:gap-4 lg:pt-21">
        <div
          class="absolute -top-21.5 left-[calc(50%-2px)] w-[193%] -translate-x-1/2 min-[375px]:-top-26 min-[375px]:left-[calc(50%+2px)] min-[375px]:w-[179%] sm:-top-28.5 sm:left-[calc(50%-5px)] sm:w-[192%] lg:-top-8.5 lg:left-[calc(50%-8px)] 2xl:-top-20 2xl:left-[calc(50%-12px)]"
        >
          <img src={FooterLogo} alt="Schnitzel Logo" class="h-auto w-full" />
        </div>
        <Typography
          variant="h4"
          tag="h4"
          className="text-7xl uppercase min-[375px]:text-8xl lg:text-[136px] lg:leading-relaxed 2xl:text-[187px]"
          >Show</Typography
        >
        <a
          href="/contact"
          class={cn(
            "min-w-32 rounded-xs bg-primary px-5 py-3 lg:-mt-4 lg:ml-10",
            textVariants({ variant: "body-sm" })
          )}
        >
          Contact Us
        </a>
      </div>
    </div>

    {/* Right Column: Navigation & Socials */}
    <div
      class="flex justify-center gap-24 uppercase sm:justify-evenly lg:flex lg:flex-1 xl:justify-normal xl:gap-30 2xl:gap-39.5"
    >
      {/* Navigation */}
      <nav class="flex flex-col gap-8 2xl:gap-12.5">
        <Typography variant="h5" tag="h5" className="mb-1"
          >NAVIGATION</Typography
        >
        {
          navigation.map(item => (
            <a
              href={item.href}
              class="decoration-2 underline-offset-4 hover:underline"
            >
              <Typography variant="h6" tag="h6">
                {item.name}
              </Typography>
            </a>
          ))
        }
      </nav>

      {/* Socials */}
      <nav class="flex flex-col gap-8 2xl:gap-12.5">
        <Typography variant="h5" tag="h5" className="mb-1">SOCIALS</Typography>
        {
          socials.map(item => (
            <a
              target="_blank"
              rel="noopener noreferrer"
              href={item.href}
              class="decoration-2 underline-offset-4 hover:underline"
            >
              <Typography variant="h6" tag="h6">
                {item.name}
              </Typography>
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>
