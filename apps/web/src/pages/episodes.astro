---
import Layout from "@/layouts/layout.astro";
import EpisodesFilters from "@/components/islands/episodes-filters";
import EpisodesList from "@/components/islands/episodes-list";
import Typography from "@/components/typography";
import { getEpisodes } from "@/lib/payload";

const search = Astro.url.searchParams.get("search") ?? undefined;
const sort = Astro.url.searchParams.get("sort") ?? "-episodeNumber";

let episodes: Awaited<ReturnType<typeof getEpisodes>>["docs"] = [];
let initialPage = 1;
let initialHasNextPage = false;
let error: string | null = null;
const fetchOnMount = import.meta.env.DEV;

if (!fetchOnMount) {
  try {
    const result = await getEpisodes({ search, sort });
    episodes = result.docs;
    initialPage = result.page;
    initialHasNextPage = result.hasNextPage;
  } catch (e) {
    error = "Could not load episodes. Please try again later.";
    console.error(e);
  }
}
---

<Layout title="All Episodes — Schnitzel Podcast">
  <main class="min-h-screen bg-primary-foreground pt-10 pb-18 md:pt-14">
    <div class="mx-auto w-full max-w-432.5 px-4 md:px-8 lg:px-6 xl:px-10">
      <!-- Page header -->
      <div
        class="mb-7 flex flex-col gap-7 lg:mb-16 lg:flex-row lg:items-center lg:justify-between"
      >
        <Typography
          tag="h1"
          variant="h1"
          uppercase={true}
          className="text-secondary lg:text-[72px] lg:leading-[86px] xl:text-[96px] xl:leading-[110px]"
        >
          All Episodes
        </Typography>

        <EpisodesFilters
          initialSearch={search ?? ""}
          initialSort={sort}
          client:load
        />
      </div>

      <!-- Episodes list -->
      <section>
        {
          error ? (
            <p class="py-16 text-center text-muted-foreground">{error}</p>
          ) : (
            <EpisodesList
              initialDocs={episodes}
              initialSearch={search ?? ""}
              initialSort={sort}
              initialPage={initialPage}
              initialHasNextPage={initialHasNextPage}
              fetchOnMount={fetchOnMount}
              client:load
            />
          )
        }
      </section>
    </div>
  </main>
</Layout>
