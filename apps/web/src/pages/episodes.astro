---
import Layout from "@/layouts/layout.astro";
import EpisodesFilters from "@/components/islands/episodes-filters";
import EpisodesList from "@/components/islands/episodes-list";
import { getEpisodes } from "@/lib/payload";
import AnimatedTitle from "@/components/islands/animated-title";

const search = Astro.url.searchParams.get("search") ?? undefined;
const sort = Astro.url.searchParams.get("sort") ?? "newest";
const SERVER_EPISODES_TIMEOUT_MS = 2500;

let episodes: Awaited<ReturnType<typeof getEpisodes>>["docs"] = [];
let initialPage = 1;
let initialHasNextPage = false;
let fetchOnMount = import.meta.env.DEV;

if (!fetchOnMount) {
  const controller = new AbortController();
  const timeout = setTimeout(
    () => controller.abort(),
    SERVER_EPISODES_TIMEOUT_MS
  );
  const cmsFetcherWithTimeout: typeof fetch = (input, init) =>
    Astro.locals.cmsFetcher(input, {
      ...init,
      signal: controller.signal,
    });

  try {
    const result = await getEpisodes({ search, sort }, cmsFetcherWithTimeout);
    episodes = result.docs;
    initialPage = result.page;
    initialHasNextPage = result.hasNextPage;
  } catch (e) {
    fetchOnMount = true;
    console.warn("[episodes] Falling back to client-side fetch", e);
  } finally {
    clearTimeout(timeout);
  }
}
---

<Layout title="Episodes — Schnitzel">
  <main class="min-h-screen bg-primary-foreground pt-10 pb-18 md:pt-14">
    <div class="mx-auto w-full max-w-432.5 px-4 md:px-8 lg:px-6 xl:px-10">
      <!-- Page header -->
      <div
        class="mb-7 flex flex-col gap-7 text-secondary lg:mb-16 lg:items-center lg:justify-between lg:gap-12.5"
      >
        <AnimatedTitle text="All Episodes" client:visible />
        <EpisodesFilters
          initialSearch={search ?? ""}
          initialSort={sort}
          client:load
        />
      </div>

      <!-- Episodes list -->
      <section>
        <EpisodesList
          initialDocs={episodes}
          initialSearch={search ?? ""}
          initialSort={sort}
          initialPage={initialPage}
          initialHasNextPage={initialHasNextPage}
          fetchOnMount={fetchOnMount}
          client:load
        />
      </section>
    </div>
  </main>
</Layout>
