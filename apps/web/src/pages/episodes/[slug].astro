---
import MarqueeWrapper from "@/components/astro/marquee/marquee-wrapper.astro";
import PodcastButton from "@/components/astro/podcast-button.astro";
import PodbeanEpisodePlayer from "@/components/islands/podbean";
import { extractPodbeanEpisodeId } from "@/components/islands/podbean/utils";
import RichTextWrapper from "@/components/islands/rich-text-wrapper";
import Typography from "@/components/typography";
import EpisodePagination from "@/components/astro/episode-pagination.astro";
import Layout from "@/layouts/layout.astro";
import {
  getAdjacentEpisodes,
  getEpisodeBySlug,
  resolveMediaUrl,
} from "@/lib/payload";
import type { SerializedEditorState } from "@payloadcms/richtext-lexical/lexical";
import { formatDateWithOrdinal, type Media } from "@schnitzel/shared";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/episodes");
}

const episode = await getEpisodeBySlug(slug);

if (!episode) {
  return new Response(null, { status: 404 });
}

const { prev, next } = await getAdjacentEpisodes(episode.episodeNumber);

const coverImage =
  episode.coverImage && typeof episode.coverImage === "object"
    ? (episode.coverImage as Media)
    : null;

const coverUrl = resolveMediaUrl(coverImage?.url);
const formattedPublishedAt = episode.publishedAt
  ? formatDateWithOrdinal(episode.publishedAt)
  : "";
const content = episode.content as SerializedEditorState | null;
const podbeanEpisodeId = extractPodbeanEpisodeId(episode.podbeanUrl);
---

<Layout title={`${episode.title} — Schnitzel Podcast`}>
  <main
    class="flex min-h-screen flex-col items-center justify-center pb-18 lg:pb-24"
  >
    <MarqueeWrapper
      imageSrc={coverUrl}
      imageAlt={episode.title}
      textPosition="below"
      marqueeText={episode.title}
      className="mb-28"
      transition:animate="fade"
    />
    <Typography variant="caption" className="text-[#7492B2]">
      {formattedPublishedAt}
    </Typography>
    <Typography
      tag="h1"
      variant="h1"
      className="text-center text-pretty text-secondary uppercase lg:mt-6"
    >
      {episode.title}
    </Typography>
    <RichTextWrapper data={content} />
    {
      episode.youtubeUrl && (
        <PodcastButton variant="secondary" href={episode.youtubeUrl} />
      )
    }
    {
      podbeanEpisodeId && (
        <PodbeanEpisodePlayer
          id={podbeanEpisodeId}
          title={episode.title}
          client:load
        />
      )
    }
    <EpisodePagination prev={prev} next={next} />
  </main>
</Layout>
